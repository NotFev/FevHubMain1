-- =============================================
-- FEVHub - Ultra Fast Title Remover + Renamer
-- Made as fast and aggressive as possible
-- =============================================

print("FEVHub Ultra Fast Loader Starting...")

-- Load the script immediately
local success, err = pcall(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/flazhy/QuantumOnyx/refs/heads/main/QuantumOnyx.lua"))()
end)

if not success then
    warn("FEVHub Load Error: " .. tostring(err))
    return
end

print("Original script loaded - Aggressive cleaning started")

-- Ultra fast cleaning function (rename + hide)
local function UltraClean()
    local core = game:GetService("CoreGui")
    
    for _, obj in ipairs(core:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            if obj.Text and #obj.Text > 1 then
                obj.Text = obj.Text:gsub("Quantum Onyx", "FEVHub")
                obj.Text = obj.Text:gsub("QuantumOnyx", "FEVHub")
                obj.Text = obj.Text:gsub("Onyx", "FEVHub")
                obj.Text = obj.Text:gsub("onyx", "FEVHub")
                obj.Text = obj.Text:gsub("quantum", "FEVHub")
            end
        end
        
        -- Try to hide title containers
        if obj:IsA("Frame") or obj:IsA("ImageLabel") or obj:IsA("ScrollingFrame") then
            local name = obj.Name:lower()
            if name:find("title") or name:find("header") or name:find("topbar") or name:find("onyx") then
                obj.Visible = false
            end
        end
    end
end

-- Start cleaning extremely early and very rapidly
task.wait(0.5)
UltraClean()

-- Super rapid burst for the first seconds
task.spawn(function()
    for i = 1, 40 do          -- 40 times very fast
        task.wait(0.08)       -- 0.08 = very aggressive speed
        UltraClean()
    end
    
    -- Then switch to normal maintenance
    while task.wait(2) do
        UltraClean()
    end
end)

print("FEVHub title cleaner running at maximum speed")
